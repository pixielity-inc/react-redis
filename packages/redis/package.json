{
  "name": "@abdokouta/react-redis",
  "version": "1.0.1",
  "description": "Client-side Redis connection management using Upstash HTTP API for React",
  "keywords": [
    "react",
    "redis",
    "upstash",
    "cache",
    "client-side",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pixielity-inc/react-redis.git"
  },
  "license": "MIT",
  "author": "Pixielity",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "dependencies": {
    "@abdokouta/react-di": "^2.0.0",
    "@upstash/redis": "^1.37.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@vitest/ui": "^4.1.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@abdokouta/react-di": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
