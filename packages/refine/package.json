{
  "name": "@abdokouta/refine",
  "version": "1.0.2",
  "description": "Refine Framework integration with dependency injection for React applications",
  "license": "MIT",
  "author": {
    "name": "Abdelrhman Kouta",
    "email": "abdelrhman@pixielity.com",
    "url": "https://github.com/abdokouta"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abdokouta/refine.git",
    "directory": "packages/refine"
  },
  "bugs": {
    "url": "https://github.com/abdokouta/refine/issues"
  },
  "homepage": "https://github.com/abdokouta/refine#readme",
  "keywords": [
    "react",
    "refine",
    "data-provider",
    "crud",
    "admin",
    "dependency-injection",
    "di",
    "hooks"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.28.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@abdokouta/react-di": "^2.0.0",
    "@refinedev/core": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@abdokouta/react-di": {
      "optional": false
    },
    "@refinedev/core": {
      "optional": false
    },
    "@tanstack/react-query": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "sideEffects": false
}
