# ─── Upstash Redis Credentials ───
# Get your credentials from https://console.upstash.com
VITE_UPSTASH_REDIS_REST_URL=""
VITE_UPSTASH_REDIS_REST_TOKEN=""

# ─── Optional: Separate Session Connection ───
VITE_UPSTASH_SESSION_REST_URL=""
VITE_UPSTASH_SESSION_REST_TOKEN=""

# ─── Default Connection ───
VITE_REDIS_DEFAULT_CONNECTION="main"
